#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

# Support two layouts:
#   Dev / flat:    repcid sits alongside main.py (repo root)
#   Installed:     repcid lives in bin/, main.py lives in ../lib/
if [[ -f "$SCRIPT_DIR/main.py" ]]; then
    LIB_DIR="$SCRIPT_DIR"
elif [[ -f "$(dirname "$SCRIPT_DIR")/lib/main.py" ]]; then
    LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"
else
    echo "[repcid] Cannot find main.py (looked in $SCRIPT_DIR and $(dirname "$SCRIPT_DIR")/lib)" >&2
    exit 1
fi

VENV_DIR="$LIB_DIR/.venv"

if [[ ! -d "$VENV_DIR" ]]; then
    echo "[repcid] Creating virtual environment..."
    python3 -m venv "$VENV_DIR"
    "$VENV_DIR/bin/pip" install --quiet -r "$LIB_DIR/requirements.txt"
elif [[ "$LIB_DIR/requirements.txt" -nt "$VENV_DIR/pyvenv.cfg" ]]; then
    echo "[repcid] requirements.txt changed, updating venv..."
    "$VENV_DIR/bin/pip" install --quiet -r "$LIB_DIR/requirements.txt"
fi

exec "$VENV_DIR/bin/python3" "$LIB_DIR/main.py" "$@"
