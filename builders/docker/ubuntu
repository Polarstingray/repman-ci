FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        ca-certificates \
        python3 \
        python3-pip \
        minisign \
    && pip3 install --break-system-packages pyinstaller \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

