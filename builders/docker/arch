FROM archlinux:latest

RUN pacman -Syu --noconfirm && \
    pacman -S --noconfirm \
        base-devel \
        python \
        python-pip \
        git \
        ca-certificates \
    && pip install --break-system-packages pyinstaller \
    && pacman -Scc --noconfirm \
    && rm -rf /var/cache/pacman/pkg/*

WORKDIR /build

