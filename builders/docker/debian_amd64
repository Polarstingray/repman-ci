FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        ca-certificates \
        python3 \
        python3-pip \
    && pip3 install --upgrade pip setuptools \
    && pip3 install pyinstaller \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

