# Absolute path to the repman-ci install root.
# Optional: auto-detected from script locations when running via repcid or main.py.
# Set explicitly if you invoke shell scripts directly without going through repcid.
# WORKING_DIR=/opt/repman-ci

# Default builder when none is specified (os_arch format)
# Available: ubuntu_amd64, arch_amd64, debian_amd64, alpine_amd64,
#            ubuntu_arm64, macos_arm64, windows_amd64
DEFAULT_BUILDER=ubuntu_amd64

# Staging directory — must be a git repo (publish_github.sh commits here)
DEFAULT_STAGE=/srv/packages

# GitHub repository base URL used to construct asset download URLs in the index
GITHUB_REPO=https://github.com/youruser/packages/releases/download

# Minisign private key passphrase
SIG_PASS=changeme

# Absolute path to the minisign private key.
# Store this outside the install directory so it survives upgrades.
CI_KEY=$HOME/.local/share/repman/ci.key

# Subdirectory under WORKING_DIR that holds the index file
INDEX_DIR=metadata

# Filename of the JSON metadata index
INDEX_FILE=index.json

# Path to the minisign public key.
# Can be absolute (recommended — survives upgrades) or relative to WORKING_DIR.
PUB_KEY1=$HOME/.local/share/repman/ci.pub

# Git branch the index is committed and pushed to after a release
PUBLISH_BRANCH=main

# Named builder groups (comma-separated, no spaces).
# Group name is uppercased at lookup time — define variables in UPPER_CASE.
# Use with: ./repcid run <project> patch -b linux   (resolves BUILDER_GROUP_LINUX)
# BUILDER_GROUP_LINUX=ubuntu_amd64,arch_amd64,debian_amd64,alpine_amd64,ubuntu_arm64
# BUILDER_GROUP_CROSS=macos_arm64,windows_amd64
